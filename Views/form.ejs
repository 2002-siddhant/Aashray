<div class="min-h-screen bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 flex items-center justify-center p-6">

  <div class="w-full max-w-2xl bg-white shadow-2xl rounded-3xl p-8 space-y-6">

    <h2 class="text-3xl font-bold text-center text-gray-800">
      <%= listing ? "Edit Listing ✏️" : "Create New Listing 🏡" %>
    </h2>

    <form 
      method="post" 
      action="<%= listing ? `/listings/${listing._id}?_method=PUT` : '/listings' %>" 
      enctype="multipart/form-data"
      class="space-y-5"
    >

      <!-- Title -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Title</label>
        <input 
          type="text" 
          name="listing[title]" 
          value="<%= listing ? listing.title : '' %>"
          placeholder="Enter Title"
          required
          class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition"
        />
      </div>

      <!-- Description -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Description</label>
        <textarea 
          rows="5" 
          name="listing[description]" 
          required
          placeholder="Enter Description"
          class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition resize-none"
        ><%= listing ? listing.description : '' %></textarea>
      </div>

      <!-- Image Upload -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Upload Image</label>
        <input 
          type="file" 
          name="listing[image]" 
          accept="image/*"
          class="w-full text-sm border rounded-xl p-2 file:bg-indigo-500 file:text-white file:px-4 file:py-2 file:rounded-lg file:border-0 hover:file:bg-indigo-600 transition"
        />
      </div>

      <!-- Price -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Price</label>
        <input 
          type="number" 
          name="listing[price]" 
          value="<%= listing ? listing.price : '' %>"
          placeholder="Enter Price"
          required
          class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition"
        />
      </div>

      <!-- Location -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Location</label>
        <input 
          type="text" 
          name="listing[location]" 
          value="<%= listing ? listing.location : '' %>"
          placeholder="Enter Location"
          required
          class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition"
        />
      </div>

      <!-- Country -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Country</label>
        <input 
          type="text" 
          name="listing[country]" 
          value="<%= listing ? listing.country : '' %>"
          placeholder="Enter Country"
          required
          class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition"
        />
      </div>

      <!-- Submit Button -->
      <button 
        type="submit"
        class="w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 hover:scale-105 transition transform duration-300 shadow-lg"
      >
        <%= listing ? "Update Listing 🚀" : "Create Listing 🚀" %>
      </button>

    </form>
  </div>

</div>
