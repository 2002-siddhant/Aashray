<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-red-100 via-pink-100 to-orange-100 px-6">

  <div class="bg-white shadow-2xl rounded-3xl p-10 max-w-lg w-full text-center space-y-6">

    <!-- Icon -->
    <div class="text-6xl">
      ⚠️
    </div>

    <!-- Heading -->
    <h1 class="text-3xl font-bold text-gray-800">
      Oops! Something Went Wrong
    </h1>

    <!-- Error Message -->
    <div class="bg-red-100 text-red-700 p-4 rounded-xl break-words">
      <%= error.message %>
    </div>

    <!-- Buttons -->
    <div class="flex justify-center gap-4 pt-4">

      <a href="/listings"
         class="px-6 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition transform hover:scale-105 shadow-md">
        Go Home 🏠
      </a>

      <button onclick="history.back()"
        class="px-6 py-2 bg-gray-200 text-gray-700 rounded-xl hover:bg-gray-300 transition transform hover:scale-105 shadow-md">
        Go Back ⬅
      </button>

    </div>

  </div>

</div>
