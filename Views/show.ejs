<div class="min-h-screen bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 py-10 px-6">

  <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden">

    <!-- Image Section -->
    <% if (listing.image && listing.image.url) { %>
  <div class="w-full aspect-[16/9] overflow-hidden">
    <img 
      src="<%= listing.image.url %>" 
      alt="Listing Image"
      class="w-full h-full object-cover"
    >
  </div>
<% } %>


    <!-- Content Section -->
    <div class="p-8 space-y-4">

      <h1 class="text-3xl font-bold text-gray-800">
        <%= listing.title %>
      </h1>

      <p class="text-gray-600 text-lg">
        <%= listing.description %>
      </p>

      <div class="grid grid-cols-2 gap-4 mt-6">

        <div class="bg-indigo-50 p-4 rounded-xl shadow-sm">
          <p class="text-sm text-gray-500">Price</p>
          <p class="text-xl font-semibold text-indigo-600">
            ₹ <%= listing.price %>
          </p>
        </div>

        <div class="bg-purple-50 p-4 rounded-xl shadow-sm">
          <p class="text-sm text-gray-500">Location</p>
          <p class="text-xl font-semibold text-purple-600">
            <%= listing.location %>, <%= listing.country %>
          </p>
        </div>

      </div>

      <!-- Buttons -->
      <div class="flex gap-4 mt-6">

        <a 
          href="/listings/edit/<%= listing._id %>" 
          class="px-6 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition transform hover:scale-105 shadow-md"
        >
          Edit ✏️
        </a>

        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
          <button 
            type="submit"
            class="px-6 py-2 bg-red-500 text-white rounded-xl hover:bg-red-600 transition transform hover:scale-105 shadow-md"
          >
            Delete 🗑
          </button>
        </form>

      </div>

    </div>

  </div>

  <!-- Review Section -->
  <div class="max-w-4xl mx-auto mt-10 bg-white rounded-3xl shadow-xl p-8">

    <h2 class="text-2xl font-bold mb-6 text-gray-800">Leave a Review ⭐</h2>

    <form method="post" action="/listings/<%= listing._id %>/reviews" class="space-y-4">

      <input 
        type="text" 
        name="review[name]" 
        placeholder="Your Name"
        required
        class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none"
      >

      <textarea 
        name="review[comment]" 
        rows="4"
        placeholder="Write your review..."
        required
        class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none resize-none"
      ></textarea>

      <div>
        <label class="block mb-2 text-gray-600 font-medium">Rating</label>
        <input 
          type="range" 
          name="review[rating]" 
          min="1" 
          max="5" 
          value="3"
          class="w-full accent-indigo-600"
        >
      </div>

      <button 
        type="submit"
        class="bg-indigo-600 text-white px-6 py-2 rounded-xl hover:bg-indigo-700 transition shadow-md"
      >
        Submit Review 🚀
      </button>

    </form>

  </div>

  <!-- Reviews Display -->
  <div class="max-w-4xl mx-auto mt-10 space-y-6">

    <% for (let review of listing.reviews) { %>

      <div class="bg-white p-6 rounded-2xl shadow-lg">

        <div class="flex justify-between items-center mb-2">
          <h3 class="text-lg font-semibold text-gray-800">
            <%= review.name %>
          </h3>
          <span class="text-yellow-500 font-bold">
            ⭐ <%= review.rating %> / 5
          </span>
        </div>

        <p class="text-gray-600 mb-2">
          <%= review.comment %>
        </p>

        <p class="text-sm text-gray-400">
          <%= review.created_at %>
        </p>

        <form 
          method="post" 
          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
          class="mt-3"
        >
          <button 
            type="submit"
            class="text-red-500 hover:text-red-600 text-sm font-medium"
          >
            Delete Review
          </button>
        </form>

      </div>

    <% } %>

  </div>

</div>
